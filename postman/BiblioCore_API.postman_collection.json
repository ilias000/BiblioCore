		{
			"name": "Loans",
			"description": "Loan management for members",
			"item": [
				{
					"name": "Borrow Book",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('loanId', response.id);",
									"    pm.test('Book borrowed', function() {",
									"        pm.expect(response.status).to.equal('ACTIVE');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
