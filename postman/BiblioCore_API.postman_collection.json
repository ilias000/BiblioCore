{
	"info": {
		"_postman_id": "bibliocore-api-collection",
		"name": "BiblioCore API",
		"description": "Library Management System API - Complete endpoint collection for testing all functionality.\n\n## Quick Start\n1. Import this collection and the environment file\n2. Run \"Register Member\" or \"Login\" to get a JWT token\n3. The token is automatically saved to the environment\n4. All authenticated requests use the token automatically\n\n## User Types\n- **Member**: Regular library user who can borrow books\n- **Admin (Librarian)**: Can manage books, members, and view all loans\n\n## Test Accounts\nAfter starting the app, register a new member or use seeded data if available.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Authentication",
			"description": "User registration and login endpoints",
			"item": [
				{
					"name": "Register Member",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('accessToken', response.accessToken);",
									"    pm.environment.set('currentUserEmail', response.email);",
									"    pm.environment.set('currentUserId', response.userId);",
									"    pm.test('Registration successful', function() {",
									"        pm.expect(response.accessToken).to.be.a('string');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john.doe@example.com\",\n    \"password\": \"SecurePass123!\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "register"]
						},
						"description": "Register a new library member account. Returns a JWT token on success."
					},
					"response": [
						{
							"name": "Success",
							"originalRequest": {
								"method": "POST",
								"body": {
									"mode": "raw",
									"raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john.doe@example.com\",\n    \"password\": \"SecurePass123!\"\n}"
								},
								"url": {
									"raw": "{{baseUrl}}/api/v1/auth/register",
									"host": ["{{baseUrl}}"],
									"path": ["api", "v1", "auth", "register"]
								}
							},
							"status": "Created",
							"code": 201,
							"_postman_previewlanguage": "json",
							"body": "{\n    \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"tokenType\": \"Bearer\",\n    \"expiresIn\": 3600,\n    \"userId\": 1,\n    \"email\": \"john.doe@example.com\",\n    \"role\": \"MEMBER\"\n}"
						}
					]
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('accessToken', response.accessToken);",
									"    pm.environment.set('currentUserEmail', response.email);",
									"    pm.environment.set('currentUserId', response.userId);",
									"    pm.test('Login successful', function() {",
									"        pm.expect(response.accessToken).to.be.a('string');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"john.doe@example.com\",\n    \"password\": \"SecurePass123!\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "login"]
						},
						"description": "Authenticate with email and password. Returns a JWT token."
					},
					"response": [
						{
							"name": "Success",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"body": "{\n    \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"tokenType\": \"Bearer\",\n    \"expiresIn\": 3600,\n    \"userId\": 1,\n    \"email\": \"john.doe@example.com\",\n    \"role\": \"MEMBER\"\n}"
						},
						{
							"name": "Invalid Credentials",
							"status": "Unauthorized",
							"code": 401,
							"_postman_previewlanguage": "json",
							"body": "{\n    \"type\": \"about:blank\",\n    \"title\": \"Unauthorized\",\n    \"status\": 401,\n    \"detail\": \"Invalid email or password\",\n    \"instance\": \"/api/v1/auth/login\"\n}"
						}
					]
				},
				{
					"name": "Login as Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('adminToken', response.accessToken);",
									"    pm.test('Admin login successful', function() {",
									"        pm.expect(response.role).to.equal('ADMIN');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@bibliocore.com\",\n    \"password\": \"Admin123!\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "login"]
						},
						"description": "Login as a librarian (admin) to access admin endpoints. Saves token to adminToken variable."
